# Inflexion — Analyse de marché consolidée (sentiment + alertes + macro + briefing)
# Déclenché automatiquement après le succès de fetch-data (workflow_run)
#
# Utilise le script consolidé generate-market-analysis.mjs qui fusionne
# 4 scripts en 2 appels Claude (au lieu de 8), réduisant la consommation
# de tokens de ~75%.
#
# Prérequis :
#   - ANTHROPIC_API_KEY dans GitHub Secrets
#   - PAT_TOKEN dans GitHub Secrets
#   - data/news.json doit exister (généré par fetch-data.yml)

name: "📊 Analyze Sentiment, Alerts & Briefing"

on:
  # Déclenché automatiquement après fetch-data
  workflow_run:
    workflows: ["📊 Fetch Market Data"]
    types: [completed]

  # Exécution manuelle depuis l'onglet Actions
  workflow_dispatch:

# Permissions nécessaires pour committer les fichiers
permissions:
  contents: write

# Une seule exécution à la fois
concurrency:
  group: "analyze-sentiment"
  cancel-in-progress: true

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  analyze:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    # Ne s'exécuter que si fetch-data a réussi (ou si déclenché manuellement/push)
    if: ${{ github.event_name != 'workflow_run' || github.event.workflow_run.conclusion == 'success' }}

    steps:
      - name: "📥 Checkout du repo"
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.PAT_TOKEN }}

      - name: "🟢 Setup Node.js 22"
        uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: 'npm'

      - name: "📦 Install dependencies"
        run: npm ci

      - name: "🔍 Vérifier la fraîcheur des données"
        id: check-data
        run: |
          LAST_DATA_CHANGE=$(git log -1 --format="%ct" -- data/)
          NOW=$(date +%s)
          DIFF=$((NOW - LAST_DATA_CHANGE))
          if [ $DIFF -gt 1800 ]; then
            echo "data_changed=false" >> $GITHUB_OUTPUT
            echo "⏭ Pas de nouvelles données (dernier commit data/ il y a ${DIFF}s)"
          else
            echo "data_changed=true" >> $GITHUB_OUTPUT
            echo "✅ Données fraîches détectées (${DIFF}s)"
          fi

      - name: "📊 Analyse de marché consolidée"
        if: steps.check-data.outputs.data_changed == 'true'
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: node scripts/generate-market-analysis.mjs

      - name: "⏭ Analyse ignorée — données inchangées"
        if: steps.check-data.outputs.data_changed != 'true'
        run: echo "Les données n'ont pas changé depuis la dernière exécution. Analyse ignorée."

      - name: "📝 Commit et push"
        if: steps.check-data.outputs.data_changed == 'true'
        run: |
          git config user.name "Inflexion Bot"
          git config user.email "bot@inflexionhub.com"

          [ -f data/sentiment.json ] && git add data/sentiment.json || true
          [ -f data/alerts.json ] && git add data/alerts.json || true
          [ -f data/macro-analysis.json ] && git add data/macro-analysis.json || true
          [ -f data/market-briefing.json ] && git add data/market-briefing.json || true

          if git diff --staged --quiet; then
            echo "Aucun changement"
            exit 0
          fi

          TIMESTAMP=$(date -u +"%Y-%m-%d %H:%M UTC")
          git commit -m "📊 Analyse marché consolidée — ${TIMESTAMP}

          Sentiment, alertes, macro et briefing via 2 appels Claude (consolidé)."

          git push
